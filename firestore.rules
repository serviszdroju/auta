rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function admin() {
      return signedIn() && exists(/databases/$(database)/documents/config/admin)
        && get(/databases/$(database)/documents/config/admin).data.uid == request.auth.uid;
    }
    function approved() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
    }

    match /config/admin {
      allow read: if signedIn();
      allow create: if signedIn() && !exists(/databases/$(database)/documents/config/admin)
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if admin();
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || admin());
      allow create: if signedIn() && (admin() || (request.auth.uid == userId
        && request.resource.data.approved == false
        && request.resource.data.role == 'pending'));
      allow update: if admin() || (signedIn() && request.auth.uid == userId
        && request.resource.data.approved == resource.data.approved
        && request.resource.data.role == resource.data.role);
      allow delete: if admin();
    }

    match /app/{document} {
      allow read, write: if approved();
    }
  }
}
